# Copy to .env and fill in. Never commit the real .env (see .gitignore).

NODE_ENV=production

# --- Database (SQLite) ---
SQLITE_FILE=/opt/kane-creek-comments-api/data/kane_creek.sqlite

# --- Server ---
PORT=10000
# Loopback only; nginx terminates TLS and proxies in. Do not change to 0.0.0.0
# unless you intend to expose the port publicly.
HOST=127.0.0.1

# --- CORS: comma-separated allowlist of site origins that may call the API ---
ALLOWED_ORIGINS=https://kanecreekwatch.org,https://www.kanecreekwatch.org
